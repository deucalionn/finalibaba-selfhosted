# ╔══════════════════════════════════════════════════════════════════════╗
# ║                   FINALIBABA — Configuration                        ║
# ║  Copy this file to .env and fill in the values.                     ║
# ║  [REQUIRED] = must be set  /  [OPTIONAL] = leave blank to disable  ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Database ───────────────────────────────────────────────────────────

# [REQUIRED] At least 16 random characters.
# Generate one: openssl rand -base64 16
POSTGRES_PASSWORD=

# Override defaults if needed (optional)
# POSTGRES_USER=appuser
# POSTGRES_DB=finalibaba

# ── NextAuth ───────────────────────────────────────────────────────────

# [REQUIRED] Secret used to sign session tokens.
# Generate one: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of the app. Required if using GoCardless or AUTH_ENABLED=true.
# Examples: http://localhost:3000  |  https://finance.yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ── Authentication (optional) ──────────────────────────────────────────
#
# By default the app is open — no login required.
# Suited for local networks, VPNs, or a reverse proxy that handles auth.
# See README → "Securing access" for alternatives (Caddy, Authelia, Cloudflare Access…)
#
# Set AUTH_ENABLED=true and one of the password options to enable built-in auth.

AUTH_ENABLED=false

# Plaintext password (simple):
# AUTH_PASSWORD=your_password_here

# Bcrypt hash (more secure):
# AUTH_PASSWORD_HASH=
# Generate: htpasswd -bnBC 10 "" your_password | tr -d ':\n'

# Display name shown in the interface:
# AUTH_USER_NAME=

# ── Open Banking PSD2 — GoCardless (optional) ──────────────────────────
#
# Connect EU and UK bank accounts via the official PSD2 API.
# Free account at: https://bankaccountdata.gocardless.com
# Free tier: 50 bank connections, 90 days of history.

GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Public URL used as the OAuth callback after bank authentication.
# Set this if the app is behind a reverse proxy.
# Leave blank to auto-detect from the request host.
# APP_URL=

# ── Automatic bank sync (all optional) ────────────────────────────────
#
# Leave credentials blank to disable the corresponding sync module.
# The app works fully without sync — you can enter balances manually.

# LCL — French bank, via Woob (web scraping)
LCL_LOGIN=
LCL_PASSWORD=

# Trade Republic — available in 18 EU countries
# Phone number in international format: +33612345678
TR_PHONE=
TR_PIN=

# ── Advanced ───────────────────────────────────────────────────────────

# Port exposed by the app container (default: 3000)
# APP_PORT=3000

# Demo mode — read-only instance with pre-seeded fictional data.
# All mutations (writes) are blocked. Use docker-compose.demo.yml for a
# full demo setup. Set both variables together.
# DEMO_MODE=true
