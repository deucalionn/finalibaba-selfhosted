# Demo instance environment — copy to .env.demo and fill in values
# docker compose -f docker-compose.demo.yml --env-file .env.demo up -d

# Required — random password for the demo DB (not exposed externally)
DEMO_POSTGRES_PASSWORD=

# Required — openssl rand -base64 32
DEMO_NEXTAUTH_SECRET=

# Public URL of the demo instance (used by NextAuth)
DEMO_URL=https://demo.example.com

# Port on the host (default: 3003)
DEMO_PORT=3003
